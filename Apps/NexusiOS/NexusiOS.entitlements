<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.developer.icloud-container-identifiers</key>
    <array>
        <string>iCloud.com.kacperpietrzyk.Nexus</string>
    </array>
    <key>com.apple.developer.icloud-services</key>
    <array>
        <string>CloudKit</string>
    </array>
    <key>aps-environment</key>
    <string>$(APS_ENVIRONMENT)</string>
    <key>com.apple.developer.ubiquity-kvstore-identifier</key>
    <string>$(TeamIdentifierPrefix)$(CFBundleIdentifier)</string>
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.kacperpietrzyk.Nexus</string>
    </array>
    <!-- On-device MLX chat/embedder models are multi-GB; without the increased
         memory limit iOS jetsams the app ("Terminated due to memory issue")
         while downloading/validating or loading a model. This raises the
         per-app memory ceiling on supported devices so the catalog's 3–6 GB
         models can be handled. (Models that still exceed the device's RAM —
         e.g. the 16 GB Qwen 27B — remain out of reach and are a separate
         catalog-sizing concern.) -->
    <key>com.apple.developer.kernel.increased-memory-limit</key>
    <true/>
</dict>
</plist>
